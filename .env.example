
# LLM & Inference Configuration
HF_TOKEN=your_huggingface_token
# Alternatively, if using OpenAI models
OPENAI_API_KEY=your_openai_api_key

# The base URL for the LLM API router
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
TEMPERATURE=0.0
OPENAI_SEED=42
REQUEST_TIMEOUT_S=90


# Environment Connectivity
# The URL of the running PII environment (Hugging Face Space or Local)
# For local: http://localhost:7860
# For HF Space: https://<username>-<space-name>.hf.space
CONTAINER_BASE_URL=http://localhost:7860

# Set to 1 to auto-launch via Docker (requires LOCAL_IMAGE_NAME)
USE_DOCKER_IMAGE=0
LOCAL_IMAGE_NAME=pii_redaction_env-env:latest


# Evaluation Control
BENCHMARK=pii-redaction-env
INFERENCE_MAX_STEPS=100
SUCCESS_SCORE_THRESHOLD=0.5

# Server Overrides (Container Environment Variables)
# PII_TASK_ID=gdpr_contract_easy
# PII_WINDOW_SIZE=500
# PII_MAX_STEPS=100